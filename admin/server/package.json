{
  "name": "haraka-admin-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript config API for the Haraka admin UI (read/write config/* files).",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:bun": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ini": "^5.0.0",
    "nodemailer": "^9.0.3",
    "redis": "^4.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ini": "^4.1.1",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
